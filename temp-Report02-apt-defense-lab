4.4 Фрагмент коду парсера (вставити моноширинним, бажано сірий фон у Word)

Нижче — актуальна функція з репозиторію (файл scripts/parse_trivy_bq.py):

def decode_blob(raw: str) -> dict[str, Any]:
    """Decode Trivy payload: plain JSON, or base64 then gzip / bzip2 / zlib then JSON."""
    cleaned = re.sub(r"\s+", "", raw)
    if not cleaned:
        raise ValueError("empty payload")
    if cleaned.startswith("{"):
        return json.loads(cleaned)
    missing_padding = len(cleaned) % 4
    if missing_padding:
        cleaned += "=" * (4 - missing_padding)
    compressed = base64.b64decode(cleaned, validate=True)
    decoders = (
        lambda blob: blob.decode("utf-8"),
        lambda blob: gzip.decompress(blob).decode("utf-8"),
        lambda blob: bz2.decompress(blob).decode("utf-8"),
        lambda blob: zlib.decompress(blob).decode("utf-8"),
    )
    for decoder in decoders:
        try:
            return json.loads(decoder(compressed))
        except (OSError, UnicodeDecodeError, json.JSONDecodeError, zlib.error):
            continue
    raise ValueError("unsupported compressed payload")

(У повному файлі також є run_from_sink з відбором рядків із довгим base64 — цитувати за потреби другим блоком.)

